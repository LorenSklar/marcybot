# Repo root: cp .env.example .env 
# Update key values in `.env` 
# NB: Never commit secrets!

# Postgres pool URI
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# OpenAI:
OPENAI_API_KEY=sk-...
# Chat (server): model and how many prior user+assistant messages to send (cap enforced server-side)
OPENAI_CHAT_MODEL=gpt-4o-mini
CHAT_MAX_MESSAGES=16

# Curriculum repo: often cloned inside this repo as ./marcy-curriculum-docs, or a sibling ../marcy-curriculum-docs
DOCS_PATH=marcy-curriculum-docs
