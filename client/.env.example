# Copy to client/.env for local Vite. Set the same vars in Render (static site) if the client is built there.

# Marcy curriculum (published) — “Read” chip opens this URL in a new tab (default: Welcome → Course Modules)
VITE_MARCY_DOCS_HOME_URL=https://marcylabschool.gitbook.io/marcy-lab-school-docs#course-modules

# Algo practice — JS Bin with JavaScript pane only (no console pane)
VITE_PRACTICE_URL=https://jsbin.com/?js
