# Repo root: cp .env.example .env 
# Update key values in `.env` 
# NB: Never commit secrets!

# Postgres pool URI
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# OpenAI:
OPENAI_API_KEY=sk-...

# Chat models
# Tutor / Call 3 (structured answer + move)
OPENAI_CHAT_MODEL=gpt-4o

# Comprehension / Call 1 (summary + studentComprehension)
OPENAI_COMPREHENSION_MODEL=gpt-4o-mini

CHAT_MAX_MESSAGES=16

# RAG
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# Markdown corpus for ingestion (clone + run ingestion/README.md). RAG reads from DB, not this path.
DOCS_PATH=marcy-curriculum-docs

# Rare: override base URL for API `sources[].url` only; default is set in server/rag.js
# CURRICULUM_SOURCE_BASE_URL=
